# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-generated-secret-here
NEXTAUTH_URL=http://localhost:3000

# PostgreSQL database (Neon / Vercel Postgres)
DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# Google OAuth (for login)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Gmail API (for email sending - can reuse same Google app)
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
# Must match your production domain when deployed
GMAIL_REDIRECT_URI=http://localhost:3000/api/gmail/callback

# Anthropic Claude API (for AI email generation)
ANTHROPIC_API_KEY=

# Optional: Cron secret for follow-up processing
CRON_SECRET=
